{
  "session_secure": true,
  "database": {
    "driver": "postgresql+psycopg"
  },
  "rate_limits": {
    "esp32_app": {
      "read":       {"limit": 60,  "period": 60},
      "live_write": {"limit": 10,  "period": 60},
      "bulk_write": {"limit": 120, "period": 60},
      "burst": true
    },
    "frontend": {"limit": 30, "period": 60},
    "login": {"limit": 3, "period": 60}
  },
  "switchbot_sync_gap_threshold_minutes": 20,
  "switchbot_sync_max_intervals_per_sensor": 20,
  "switchbot_sync_max_intervals_total": 50,
  "switchbot_bulk_max_readings": 200,
  "levoit_ah_controller": {
    "switchbot_mac": "EC:2E:84:06:4E:9A",
    "target_absolute_humidity": 8.0
  }
}
